@echo off
chcp 65001 >nul
title 🔧 Wails3 Build & Compress Script

echo ============================================
echo 🔧 เริ่มต้น Build โปรเจกต์...
echo ============================================
start /wait wails3 build

echo.
echo ============================================
echo 🔧 กำลังบีบอัดและลบข้อมูล debug...
echo ============================================
for %%f in ("build\bin\*.exe") do (
    echo 🔹 ลดขนาดไฟล์ %%~nxf ...
    upx --best --lzma "%%f"
)

echo.
echo ============================================
echo ✅ เสร็จสิ้นขั้นตอน Build และลดขนาดไฟล์!
echo ============================================
pause

echo.
echo ============================================
echo 📦 เริ่ม Package...
echo ============================================
start wails3 package
